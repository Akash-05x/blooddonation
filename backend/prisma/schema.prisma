// This is your Prisma schema file
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  admin
  hospital
  donor
}

enum BloodGroup {
  A_POS  @map("A+")
  A_NEG  @map("A-")
  B_POS  @map("B+")
  B_NEG  @map("B-")
  O_POS  @map("O+")
  O_NEG  @map("O-")
  AB_POS @map("AB+")
  AB_NEG @map("AB-")
}

enum HospitalType {
  Govt
  Private
  Clinic
  Diagnostic
}

enum ControllingDept {
  DMRHS
  DME
}

enum HospitalCategory {
  PHC
  CHC
  District
  MedicalCollege
}

enum AvailableTime {
  Any
  Day
  Night
}

enum EmergencyLevel {
  low
  medium
  high
  critical
}

// Full request lifecycle state machine
enum RequestStatus {
  created               // Initial state when hospital submits request
  donor_search          // Searching for compatible donors
  awaiting_confirmation // Top-10 donors notified, waiting for responses
  assigned              // Primary + secondary donors assigned
  in_transit            // Primary donor accepted and on the way
  completed             // Donation successfully done
  closed                // Request fully closed after completion
  failed                // No donors found or all rejected
  cancelled             // Manually cancelled by hospital
  expired               // Timed out without resolution
}

enum AssignmentRole {
  primary
  backup
  reserve
}

enum AssignmentStatus {
  pending
  accepted
  rejected
  arrived
  completed
  promoted
  failed
}

enum DonationStatus {
  successful
  failed
  pending
}

enum OTPStatus {
  pending
  used
  expired
  locked
}

enum VerificationStatus {
  pending
  approved
  rejected
}

// Notification token status for donor confirmation flow
enum TokenStatus {
  pending
  confirmed
  expired
  cancelled
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  name         String
  email        String?   @unique
  phone        String?   @unique
  password     String
  role         UserRole
  otp_verified Boolean   @default(false)
  is_blocked   Boolean   @default(false)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  hospital  Hospital?
  donor     Donor?
  otpLogs   OTPLog[]
  adminLogs AdminLog[]

  @@map("users")
}

model Hospital {
  id                     String             @id @default(uuid())
  user_id                String             @unique

  // Basic Info
  hospital_name          String
  district               String             @default("")
  address                String
  telephone              String             @default("")
  official_email         String             @default("")
  latitude               Float
  longitude              Float
  hospital_type          HospitalType       @default(Govt)

  // Govt-specific
  controlling_dept       ControllingDept?
  hospital_category      HospitalCategory?

  // Private-specific
  clinical_reg_no        String?
  issue_date             DateTime?
  expiry_date            DateTime?
  issuing_authority      String?

  // Optional National IDs
  nabh_accreditation_no  String?
  abdm_facility_id       String?

  // Authorized Person
  authorized_person_name String             @default("")
  authorized_designation String             @default("")
  authorized_email       String             @default("")

  verified_status        VerificationStatus @default(pending)
  created_at             DateTime           @default(now())
  updated_at             DateTime           @updatedAt

  user              User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  emergencyRequests EmergencyRequest[]
  donationHistory   DonationHistory[]

  @@map("hospitals")
}

model Donor {
  id                    String        @id @default(uuid())
  user_id               String        @unique
  name                  String

  // Personal Details
  gender                String        @default("Male")
  dob                   DateTime?
  age                   Int
  body_weight           Float?

  // Blood & Medical
  blood_group           BloodGroup
  major_illness         String?
  taking_medication_date DateTime?
  last_donation_date    DateTime?
  recent_surgery_date   DateTime?
  is_pregnant           Boolean       @default(false)

  // Location
  district              String?
  address               String?
  latitude              Float?
  longitude             Float?

  // Availability
  available_time        AvailableTime @default(Any)
  willing_to_travel     Boolean       @default(true)

  // Identity & Safety
  id_proof_type         String?
  id_proof_no           String?
  consent_declaration   Boolean       @default(false)

  // Legacy / Operational
  medical_notes         String?
  availability_status   Boolean       @default(true)
  reliability_score     Float         @default(100.0)
  donation_count        Int           @default(0)      // Total successful donations
  vacation_mode         Boolean       @default(false)
  last_response_time    DateTime?

  created_at            DateTime      @default(now())
  updated_at            DateTime      @updatedAt

  user                User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  assignments         DonorAssignment[]
  donationHistory     DonationHistory[]
  notificationTokens  NotificationToken[]
  locationHistory     DonorLocation[]

  @@map("donors")
}

model EmergencyRequest {
  id              String         @id @default(uuid())
  hospital_id     String
  blood_group     BloodGroup
  units_required  Int
  emergency_level EmergencyLevel @default(high)
  status          RequestStatus  @default(created)
  notes           String?
  is_locked       Boolean        @default(false)  // Critical section lock to prevent race conditions
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  hospital            Hospital            @relation(fields: [hospital_id], references: [id], onDelete: Cascade)
  assignments         DonorAssignment[]
  history             DonationHistory[]
  notificationTokens  NotificationToken[]
  locationHistory     DonorLocation[]

  @@map("emergency_requests")
}

model DonorAssignment {
  id            String           @id @default(uuid())
  request_id    String
  donor_id      String
  role          AssignmentRole   @default(primary)
  status        AssignmentStatus @default(pending)
  score         Float?           // Ranking score at time of assignment
  distance_km   Float?           // Distance to hospital at time of assignment
  assigned_time DateTime         @default(now())
  responded_at  DateTime?
  arrived_at    DateTime?
  updated_at    DateTime         @updatedAt

  request EmergencyRequest @relation(fields: [request_id], references: [id], onDelete: Cascade)
  donor   Donor            @relation(fields: [donor_id], references: [id], onDelete: Cascade)

  @@unique([request_id, donor_id])
  @@map("donor_assignments")
}

model DonationHistory {
  id            String         @id @default(uuid())
  donor_id      String
  hospital_id   String
  request_id    String
  donation_date DateTime       @default(now())
  status        DonationStatus @default(successful)
  notes         String?
  points_earned Int            @default(0)   // Points awarded (50 for urgent, 100 for critical)

  donor    Donor            @relation(fields: [donor_id], references: [id], onDelete: Cascade)
  hospital Hospital         @relation(fields: [hospital_id], references: [id], onDelete: Cascade)
  request  EmergencyRequest @relation(fields: [request_id], references: [id], onDelete: Cascade)

  @@map("donation_history")
}

// ─── Notification Tokens ──────────────────────────────────────────────────────
// Stores secure tokens sent to top-10 donors for confirmation

model NotificationToken {
  id          String      @id @default(uuid())
  donor_id    String
  request_id  String
  token       String      @unique   // Cryptographically secure random token
  status      TokenStatus @default(pending)
  expires_at  DateTime              // Token validity window (e.g. 10 minutes)
  responded_at DateTime?            // When donor confirmed
  created_at  DateTime    @default(now())

  donor   Donor            @relation(fields: [donor_id], references: [id], onDelete: Cascade)
  request EmergencyRequest @relation(fields: [request_id], references: [id], onDelete: Cascade)

  @@map("notification_tokens")
}

// ─── Donor Location Tracking ─────────────────────────────────────────────────
// Stores GPS pings from the primary donor during transit

model DonorLocation {
  id          String   @id @default(uuid())
  donor_id    String
  request_id  String
  latitude    Float
  longitude   Float
  recorded_at DateTime @default(now())

  donor   Donor            @relation(fields: [donor_id], references: [id], onDelete: Cascade)
  request EmergencyRequest @relation(fields: [request_id], references: [id], onDelete: Cascade)

  @@map("donor_locations")
}

model OTPLog {
  id          String    @id @default(uuid())
  user_id     String
  otp_code    String
  expiry_time DateTime
  attempts    Int       @default(0)
  status      OTPStatus @default(pending)
  purpose     String    @default("verification") // "verification" | "reset"
  created_at  DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("otp_logs")
}

model SystemConfiguration {
  id                         String   @id @default(uuid())
  distance_radius            Float    @default(50.0)   // km
  ranking_weight_response    Float    @default(0.5)    // responseSpeed weight
  ranking_weight_distance    Float    @default(0.3)    // distanceScore weight
  ranking_weight_history     Float    @default(0.2)    // donationHistory weight
  gps_timeout_minutes        Int      @default(2)      // Minutes before GPS timeout triggers failover
  notification_expiry_minutes Int     @default(10)     // Token expiry for donor confirmation
  created_at                 DateTime @default(now())
  updated_at                 DateTime @updatedAt

  @@map("system_configurations")
}

model AdminLog {
  id             String   @id @default(uuid())
  admin_id       String
  action         String
  target_user_id String?
  details        Json?
  timestamp      DateTime @default(now())

  admin User @relation(fields: [admin_id], references: [id], onDelete: Cascade)

  @@map("admin_logs")
}

model PendingHospital {
  id                     String           @id @default(uuid())
  hospital_name          String
  email                  String?
  phone                  String?
  password               String           // Hashed
  district               String           @default("")
  address                String           @default("")
  telephone              String           @default("")
  official_email         String           @default("")
  latitude               Float            @default(0)
  longitude              Float            @default(0)
  hospital_type          HospitalType     @default(Govt)
  controlling_dept       ControllingDept?
  hospital_category      HospitalCategory?
  clinical_reg_no        String?
  issue_date             DateTime?
  expiry_date            DateTime?
  issuing_authority      String?
  nabh_accreditation_no  String?
  abdm_facility_id       String?
  authorized_person_name String           @default("")
  authorized_designation String           @default("")
  authorized_email       String           @default("")
  created_at             DateTime         @default(now())

  @@map("pending_hospitals")
}

