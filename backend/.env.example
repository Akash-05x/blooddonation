# ─── Database ───────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/blood_request_db"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── OTP ─────────────────────────────────────────────────────────────────────
# Set to "true" to print OTPs to console instead of sending email (dev mode)
OTP_CONSOLE_MODE=true
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5

# ─── Email / SMTP (only required if OTP_CONSOLE_MODE=false) ──────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM="Blood Request System <no-reply@bloodrequest.com>"

# ─── Frontend CORS origin ────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173
